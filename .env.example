# Public site URL (used in sitemap, canonicals, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://rentacarsifnos.com

# Analytics (optional, omit to disable scripts)
NEXT_PUBLIC_CF_BEACON_TOKEN=
NEXT_PUBLIC_GA_ID=G-16VR49ZQ7X

# Touristas AI: Vercel AI Gateway (preferred) or OpenAI
AI_GATEWAY_API_KEY=
# OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

# Booking emails via Resend (optional, enquiries log to console if unset)
RESEND_API_KEY=
BOOKING_FROM_EMAIL=Artemis Rental <bookings@artemisrental.gr>

# Formspree inbox (public form id, wired in src/lib/formspree.ts)
# https://formspree.io/f/xaqrovvz

# Optional WhatsApp click-to-chat override (E.164). Defaults to business.json
# NEXT_PUBLIC_WHATSAPP=+306985908478

# WhatsApp Cloud API — business → guest enquiry ack (optional, soft-fails)
# Create at https://developers.facebook.com/ → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_API_VERSION=v21.0
# For first contact outside 24h window, use an approved template (body {{1}}=name)
# WHATSAPP_TEMPLATE_NAME=enquiry_received
# WHATSAPP_TEMPLATE_LANG=en
